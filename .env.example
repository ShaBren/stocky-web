# Docker Compose Environment Variables
# Copy this file to .env and customize for your deployment

# === Frontend Configuration ===
# API endpoint that the frontend will connect to
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Application metadata
VITE_APP_NAME=StockyWeb
VITE_APP_VERSION=0.0.1

# Feature flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false
VITE_ENABLE_HTTPS_ONLY=true

# Environment
VITE_ENVIRONMENT=production

# === Runtime Configuration (Container Deployment) ===
# These variables override build-time config when using Docker containers
# Use these to deploy the same image to different environments
RUNTIME_API_BASE_URL=http://localhost:8000/api/v1
RUNTIME_APP_NAME=StockyWeb
RUNTIME_APP_VERSION=0.0.1
RUNTIME_ENABLE_ANALYTICS=false
RUNTIME_ENABLE_DEBUG=false
RUNTIME_ENABLE_HTTPS_ONLY=true
RUNTIME_ENVIRONMENT=production

# === Service Ports ===
# Port to expose the web frontend on
WEB_PORT=3000

# Port to expose the API backend on (when backend is enabled)
API_PORT=8000

# Port to expose the database on (when database is enabled)
DB_PORT=5432

# === Backend Configuration (when backend service is enabled) ===
# Database connection string
DATABASE_URL=sqlite:///app/data/stocky.db
# For PostgreSQL: postgresql://stocky:secure_password@db:5432/stocky

# Backend security
SECRET_KEY=your-secret-key-here-change-in-production

# CORS origins (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Backend debug mode
DEBUG=false

# === Database Configuration (when PostgreSQL is enabled) ===
POSTGRES_DB=stocky
POSTGRES_USER=stocky
POSTGRES_PASSWORD=secure_password

# === Docker Configuration ===
# Container restart policy: no, always, on-failure, unless-stopped
RESTART_POLICY=unless-stopped

# === Network Configuration ===
# Docker network name
NETWORK_NAME=stocky-network